<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@color/surface_dark"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Row: Badges -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvCardStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/badge_green"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="Visited ✓"
                android:textColor="@color/badge_green_text"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone"
                android:layout_marginEnd="8dp"  android:fontFamily="@font/poppins_family"/>

            <TextView
                android:id="@+id/tvCardCuisine"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/badge_orange"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                tools:text="Pakistani"
                android:textColor="@color/primary_orange"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp"  android:fontFamily="@font/poppins_family"/>

            <TextView
                android:id="@+id/tvCardPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/badge_gray"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                tools:text="$$"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp"  android:fontFamily="@font/poppins_family"/>

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvCardSpendBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/badge_gray"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                tools:text="Rs. 1,400"
                android:textColor="@color/primary_orange"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone"  android:fontFamily="@font/poppins_family"/>
        </LinearLayout>

        <!-- Restaurant Name -->
        <TextView
            android:id="@+id/tvCardName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            tools:text="The Monal"
            android:textColor="@color/primary_orange"
            android:fontFamily="@font/hamburger"
            android:textSize="24sp"
            android:layout_marginBottom="4dp" />

        <!-- Address -->
        <TextView
            android:id="@+id/tvCardAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            tools:text="Pir Sohawa, Islamabad"
            android:textColor="@color/divider_color"
            android:textSize="12sp"
            android:layout_marginBottom="10dp"  android:fontFamily="@font/poppins_family"/>

        <!-- Tags/Occasions -->
        <LinearLayout
            android:id="@+id/layoutTags"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/tvTag1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/badge_tag"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:textColor="@color/text_muted"
                android:textSize="10sp"
                android:layout_marginEnd="6dp"
                tools:text="Date Night"  android:fontFamily="@font/poppins_family"/>

            <TextView
                android:id="@+id/tvTag2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/badge_tag"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:textColor="@color/text_muted"
                android:textSize="10sp"
                android:visibility="gone"
                tools:text="Family"  android:fontFamily="@font/poppins_family"/>
        </LinearLayout>

        <!-- Rating Bar -->
        <ProgressBar
            android:id="@+id/pbCardRating"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:progress="80"
            android:progressDrawable="@drawable/rating_progress"
            android:layout_marginBottom="8dp" />

        <!-- Rating Display -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvCardRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="4/5"
                android:textColor="@color/primary_orange"
                android:textStyle="bold"
                android:textSize="13sp"
                android:layout_marginEnd="6dp"  android:fontFamily="@font/poppins_family"/>

            <TextView
                android:id="@+id/tvCardStars"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="★★★★☆"
                android:textColor="@color/primary_orange"
                android:textSize="12sp"  android:fontFamily="@font/poppins_family"/>
        </LinearLayout>

        <!-- Best Dish Section (Visible only for Visited) -->
        <LinearLayout
            android:id="@+id/layoutBestDish"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="4dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider_color"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Best Dish:"
                android:textColor="@color/divider_color"
                android:textSize="10sp"
                android:layout_marginBottom="4dp"  android:fontFamily="@font/poppins_family"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvBestDishName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    tools:text="Nihari"
                    android:textColor="@color/primary_orange"
                    android:textStyle="bold"
                    android:textSize="13sp"  android:fontFamily="@font/poppins_family"/>

                <TextView
                    android:id="@+id/tvBestDishStars"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="★★★★★"
                    android:textColor="@color/primary_orange"
                    android:textSize="11sp"  android:fontFamily="@font/poppins_family"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>

